{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "uploaded-image-filename.png"
    }
  },
  "2": {
    "class_type": "KlingImage2VideoNode",
    "inputs": {
      "start_frame": ["1", 0],
      "prompt": "Description of desired motion and scene, cinematic 4K",
      "negative_prompt": "blurry, distorted, low quality, cartoon, anime, morphing",
      "model_name": "kling-v2-master",
      "cfg_scale": 0.8,
      "mode": "std",
      "aspect_ratio": "16:9",
      "duration": "5"
    }
  },
  "3": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["2", 0],
      "filename_prefix": "video/scene",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
